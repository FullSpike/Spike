<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.week02.mapper.studentMapper">

<!-- 插入学生 -->
    <insert id="insertStudent">
        insert into student (number, password) values (#{number}, #{password})
    </insert>
<!-- 根据学号查询学生 -->
    <select id="findStudentByNumber" resultType="org.example.week02.pojo.Student">
            select * from student where number = #{number}
        </select>
       </mapper>
