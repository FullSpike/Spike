<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.week02.mapper.fixOrderMapper">
    <update id="updateOrder">
        update order0 set status = #{status} where id = #{id}
    </update>

    <!--    删除订单 -->
    <delete id="deleteOrder" parameterType="long">
        delete from order0 where id = #{id}
    </delete>


    <!--    根据f_id查询订单列表 -->
    <select id="selectOrdersByF_id" resultType="org.example.week02.pojo.Order">
        select * from order0 where f_id = #{f_id}
    </select>
    <!--    根据id查询订单 -->
    <select id="selectOrderById" resultType="org.example.week02.pojo.Order">
        select * from order0 where id = #{id}
    </select>
    <select id="selectAll" resultType="org.example.week02.pojo.Order">
        select * from order0
    </select>
    <select id="selectProcessOrder" resultType="org.example.week02.pojo.Order">
        select * from order0 where status = '已处理'
    </select>
    <select id="selectUnProcessOrder" resultType="org.example.week02.pojo.Order">
        select * from order0 where status = '未处理'
    </select>
</mapper>
