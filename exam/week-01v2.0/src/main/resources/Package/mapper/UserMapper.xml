<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Package.mapper.UserMapper">
    <!-- 注册学生 -->
    <insert id="registerStudent" parameterType="java.util.Map">
        insert into student (number, password) values (#{number}, #{password})
    </insert>
    <!-- 注册管理员 -->
    <insert id="registerAdmin" parameterType="java.util.Map">
        insert into admin (number, password) values (#{number}, #{password})
    </insert>
    <!-- 更新宿舍号 -->
    <update id="updateRoom">
        update student set room=#{room} where number=#{number}
    </update>
    <!-- 更新密码 -->
    <update id="updatePassword">
        update student set password=#{newPassword} where number=#{number}
    </update>
    <!-- 更新报修单状态 -->
    <update id="updateOrderStatus">
        update order0 set status=#{status}, last_time=#{last_time} where id=#{id}
    </update>
    <!-- 更新管理员密码 -->
    <update id="updateAdminPassword">
        update admin set password=#{password} where number=#{number}
    </update>

    <!-- 学生登录 -->
    <select id="studentLogin" resultType="java.lang.Integer">
        select count(*) from student where number=#{number} and password=#{password}
    </select>
    <!-- 查询学生宿舍号 -->
    <select id="selectRoomByNumber" resultType="java.lang.String">
        select room from student where number=#{number}
    </select>
    <!-- 查询学生ID -->
    <select id="selectIdByNumber" resultType="java.lang.Integer">
        select id from student where number=#{number}
    </select>
    <!-- 查询学生是否存在 -->
    <select id="selectByNumber" resultType="java.lang.Integer">
        select count(*) from student where number=#{number}
    </select>
    <!-- 查询管理员是否存在 -->
    <select id="selectAdminByNumber" resultType="java.lang.Integer">
        select count(*) from admin where number=#{number}
    </select>
    <!-- 管理员登录 -->
    <select id="adminLogin" resultType="java.lang.Integer">
        select count(*) from admin where number=#{number} and password=#{password}
    </select>


</mapper>